<ui:FluentWindow x:Class="NotepadMinus.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:v="clr-namespace:NotepadMinus.Views"
                 Title="notepad--"
                 Width="1100" Height="720"
                 MinWidth="640" MinHeight="400"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 FontFamily="Segoe UI"
                 Background="{DynamicResource ChromeBackground}"
                 Foreground="{DynamicResource ChromeForeground}">

    <ui:FluentWindow.Resources>
        <!-- Soft, rounded tab style. Compact so the editor sits right below the tab strip. -->
        <Style x:Key="SoftTabItem" TargetType="TabItem">
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="2,2,2,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource SubtleBorder}"
                                BorderThickness="1"
                                CornerRadius="8,8,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource EditorBackground}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1,1,1,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SubtleBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource ChromeBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource ChromeForeground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ContextMenu x:Key="SidebarItemContextMenu">
            <MenuItem Header="Open" Click="Ctx_Open"/>
            <MenuItem Header="Reveal in File Explorer" Click="Ctx_Reveal"/>
            <MenuItem Header="Copy full path" Click="Ctx_CopyPath"/>
            <MenuItem Header="Copy filename" Click="Ctx_CopyName"/>
            <MenuItem Header="Rename" Click="Ctx_Rename"/>
            <Separator/>
            <MenuItem Header="Delete" Click="Ctx_Delete"/>
        </ContextMenu>
    </ui:FluentWindow.Resources>

    <DockPanel LastChildFill="True">
        <!-- Integrated Chrome/Edge-style title bar. Compact, with a larger app icon. -->
        <ui:TitleBar x:Name="TitleBarControl"
                     DockPanel.Dock="Top"
                     Title="notepad--"
                     Height="36"
                     ShowMaximize="True"
                     ShowMinimize="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/icon.ico" Width="22" Height="22"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Menu sits directly below the title bar. -->
        <Menu DockPanel.Dock="Top"
              Background="Transparent"
              Foreground="{DynamicResource ChromeForeground}"
              Padding="8,2">
            <MenuItem Header="_File">
                <MenuItem Header="_New Tab" InputGestureText="Ctrl+T" Click="NewTab_Click"/>
                <MenuItem Header="New _Window" InputGestureText="Ctrl+N" Click="NewWindow_Click"/>
                <MenuItem Header="_Open File…" InputGestureText="Ctrl+O" Click="OpenFile_Click"/>
                <MenuItem Header="_Close Tab" InputGestureText="Ctrl+W" Click="CloseTab_Click"/>
                <MenuItem Header="Reopen Closed Tab" InputGestureText="Ctrl+Shift+T" Click="ReopenClosedTab_Click"/>
                <Separator/>
                <MenuItem Header="_Export Notes…" Click="ExportNotes_Click"/>
                <MenuItem Header="_Import Notes…" Click="ImportNotes_Click"/>
                <Separator/>
                <MenuItem Header="Reveal Notes Folder in Explorer" Click="RevealFolder_Click"/>
                <MenuItem Header="Open config.json" InputGestureText="Ctrl+," Click="OpenConfig_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Command="ApplicationCommands.Undo"/>
                <MenuItem Command="ApplicationCommands.Redo"/>
                <Separator/>
                <MenuItem Command="ApplicationCommands.Cut"/>
                <MenuItem Command="ApplicationCommands.Copy"/>
                <MenuItem Command="ApplicationCommands.Paste"/>
                <MenuItem Command="ApplicationCommands.SelectAll"/>
                <Separator/>
                <MenuItem Header="Find…" InputGestureText="Ctrl+F" Click="Find_Click"/>
                <MenuItem Header="Replace…" InputGestureText="Ctrl+H" Click="Replace_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="SidebarMenuItem" Header="Toggle Sidebar" InputGestureText="Ctrl+B" IsCheckable="True" Click="ToggleSidebar_Click"/>
                <MenuItem x:Name="WordWrapMenuItem" Header="Word Wrap" IsCheckable="True" Click="WordWrap_Click"/>
                <MenuItem x:Name="LineNumberMenuItem" Header="Show Line Numbers" IsCheckable="True" IsChecked="True" Click="LineNumber_Click"/>
                <Separator/>
                <MenuItem Header="_Theme">
                    <MenuItem x:Name="ThemeSystemItem" Header="System" IsCheckable="True" Click="ThemeSystem_Click"/>
                    <MenuItem x:Name="ThemeLightItem"  Header="Light"  IsCheckable="True" Click="ThemeLight_Click"/>
                    <MenuItem x:Name="ThemeSepiaItem"  Header="Sepia"  IsCheckable="True" Click="ThemeSepia_Click"/>
                    <MenuItem x:Name="ThemeDimItem"    Header="Dim"    IsCheckable="True" Click="ThemeDim_Click"/>
                    <MenuItem x:Name="ThemeDarkItem"   Header="Dark"   IsCheckable="True" Click="ThemeDark_Click"/>
                </MenuItem>
                <MenuItem Header="_Font">
                    <MenuItem x:Name="FontSansItem"  Header="Sans"  IsCheckable="True" Click="FontSans_Click"/>
                    <MenuItem x:Name="FontSerifItem" Header="Serif" IsCheckable="True" Click="FontSerif_Click"/>
                    <MenuItem x:Name="FontMonoItem"  Header="Mono"  IsCheckable="True" Click="FontMono_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Zoom In" InputGestureText="Ctrl++" Click="ZoomIn_Click"/>
                <MenuItem Header="Zoom Out" InputGestureText="Ctrl+-" Click="ZoomOut_Click"/>
                <MenuItem Header="Reset Zoom" InputGestureText="Ctrl+0" Click="ZoomReset_Click"/>
            </MenuItem>
        </Menu>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource SidebarBackground}"
                   Foreground="{DynamicResource ChromeForeground}">
            <StatusBarItem>
                <TextBlock x:Name="NotesFolderLabel" Foreground="{DynamicResource ChromeForeground}" Opacity="0.7" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="CaretLabel" Foreground="{DynamicResource ChromeForeground}" Opacity="0.7" FontSize="11" Margin="0,0,8,0"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Body -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="280" MinWidth="0"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border x:Name="SidebarPanel" Grid.Column="0"
                    Background="{DynamicResource SidebarBackground}"
                    BorderBrush="{DynamicResource SubtleBorder}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="12,12,12,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Notes" FontWeight="SemiBold" Margin="2,0,0,6" Foreground="{DynamicResource ChromeForeground}"/>
                        <TextBox x:Name="SearchBox" Grid.Row="1"
                                 Style="{StaticResource RoundedTextBox}"
                                 TextChanged="SearchBox_TextChanged"
                                 ToolTip="Search file names, #tags, and file contents."/>
                    </Grid>

                    <ListBox x:Name="NotesList"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource ChromeForeground}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="NotesList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="Margin" Value="6,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarHover}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarSelected}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="ContextMenu" Value="{StaticResource SidebarItemContextMenu}"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayTitle}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource ChromeForeground}"/>
                                    <TextBlock Text="{Binding SubText}" FontSize="11" Foreground="{DynamicResource ChromeForeground}" Opacity="0.6"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- Editor -->
            <Grid Grid.Column="2" Background="{DynamicResource EditorBackground}">
                <TabControl x:Name="Tabs" BorderThickness="0" Background="Transparent"
                            ItemContainerStyle="{StaticResource SoftTabItem}">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" ToolTip="{Binding FilePath}">
                                <TextBlock Text="{Binding DisplayTitle}" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                                <Button Content="✕"
                                        Margin="8,0,0,0"
                                        Padding="4,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{DynamicResource ChromeForeground}"
                                        Opacity="0.6"
                                        Cursor="Hand"
                                        Click="CloseTabButton_Click"
                                        Tag="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="LineGutter" Grid.Column="0"
                                         IsReadOnly="True"
                                         IsHitTestVisible="False"
                                         Focusable="False"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource ChromeForeground}"
                                         Opacity="0.55"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         TextAlignment="Right"
                                         Padding="10,6,8,6"
                                         MinWidth="40"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Hidden"
                                         HorizontalScrollBarVisibility="Hidden"
                                         Loaded="LineGutter_Loaded"
                                         Unloaded="LineGutter_Unloaded"/>
                                <TextBox x:Name="BodyEditor" Grid.Column="1"
                                         Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         AcceptsTab="True"
                                         AutoWordSelection="False"
                                         SpellCheck.IsEnabled="False"
                                         BorderThickness="0"
                                         Padding="6,6,12,6"
                                         Background="{DynamicResource EditorBackground}"
                                         Foreground="{DynamicResource EditorForeground}"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         UndoLimit="500"
                                         TextWrapping="NoWrap"
                                         Loaded="BodyEditor_Loaded"
                                         Unloaded="BodyEditor_Unloaded"
                                         SelectionChanged="BodyEditor_SelectionChanged"
                                         TextChanged="BodyEditor_TextChanged"
                                         PreviewMouseWheel="BodyEditor_PreviewMouseWheel"
                                         Tag="{Binding}"/>
                                <!-- Floating in-file Find overlay (top-right of editor column). -->
                                <v:FindBar x:Name="FindBarControl" Grid.Column="1"
                                           HorizontalAlignment="Right" VerticalAlignment="Top"
                                           Margin="0,8,16,0"
                                           Panel.ZIndex="100"
                                           Visibility="Collapsed"
                                           Loaded="FindBarControl_Loaded"
                                           Unloaded="FindBarControl_Unloaded"/>
                            </Grid>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </Grid>
        </Grid>
    </DockPanel>
</ui:FluentWindow>