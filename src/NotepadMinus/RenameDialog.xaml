<Window x:Class="NotepadMinus.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename"
        Width="420" Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource ChromeBackground}"
        Foreground="{DynamicResource ChromeForeground}"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="New name" Margin="0,0,0,6"/>
        <TextBox  Grid.Row="1" x:Name="NameBox" Padding="6,4"
                  BorderBrush="{DynamicResource SubtleBorder}"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
            <Button Content="OK"     Width="80" Click="Ok_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
